{
  "name": "@scavio/ai-sdk",
  "version": "0.2.1",
  "description": "Scavio search tools for the Vercel AI SDK (Google, YouTube, Reddit, Amazon, Walmart, TikTok, Instagram).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "scavio",
    "ai",
    "vercel-ai-sdk",
    "tools",
    "search",
    "agents"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scavio-ai/scavio-ai.git"
  },
  "homepage": "https://scavio.dev",
  "peerDependencies": {
    "ai": ">=4",
    "zod": ">=3"
  },
  "dependencies": {
    "scavio": "^0.2.1"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "ai": "^6.0.208",
    "scavio": "^0.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  }
}
